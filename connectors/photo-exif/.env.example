# Where LifeContext is running and its shared secret (set to the same value as LIFECONTEXT_API_KEY
# in the core server's own .env — that's the literal env var name life-context reads).
LIFECONTEXT_URL=http://localhost:3000
LIFECONTEXT_API_KEY=change-this-to-a-long-secure-token

# Root of the photo archive to scan (recursively). Required for both scan.js and caption-worker.js.
PHOTO_ROOT=/path/to/your/photos

# Force whether PHOTO_ROOT is treated as a Google Takeout export ('true'/'false'). Omit to
# auto-detect (root is/contains a "Google Photos" dir, or has a "Photos from <YYYY>" bucket /
# album metadata.json). Takeout media key source='google-photos'; everything else 'photo-exif'.
# PHOTO_TAKEOUT=true

# scan.js: where the "already scanned, unchanged" cache lives (mtime+size keyed).
# PHOTO_EXIF_MANIFEST_PATH=/home/you/.life-context/photo-exif-manifest.json

# scan.js: wall-clock interval (ms) for the throttled progress line + mid-run manifest
# persistence (so a killed scan resumes to within one interval). 0 disables both (manifest
# written only at end). Default 30000.
# PHOTO_EXIF_PROGRESS_INTERVAL_MS=30000

# caption-worker.js: local Ollama endpoint — uses Ollama's NATIVE /api/generate (not the
# OpenAI-compat /v1 endpoint), since that's what supports sending image data — and the vision
# model to use.
# VLM_BASE_URL=http://localhost:11434
# VLM_MODEL=llava
# VLM_PROMPT=Describe this photo in one concise sentence, focused on what's happening and who or what is visible.

# caption-worker.js: delay between captions (ms) — keeps this a genuinely low-priority,
# background-only load on whatever machine runs the VLM.
# VLM_THROTTLE_MS=2000

# caption-worker.js: where the "already captioned" state lives. As of #53 this is a
# relPath -> caption-text map (a legacy array from older runs is still read).
# PHOTO_EXIF_CAPTION_STATE_PATH=/home/you/.life-context/photo-exif-captions.json

# --- face-worker.js (#53): local, offline face detection -> `pictured` entity hints ---
# Directory holding the face-api model weights (ssdMobilenetv1 + faceLandmark68Net +
# faceRecognitionNet). One-time download, fully offline after. Required to run `node face-worker.js`
# (scan). See README "Face detection" for the download step.
# FACE_MODELS_PATH=/home/you/.life-context/face-models

# Euclidean distance below which two face descriptors are treated as the same person (cluster).
# FACE_MATCH_THRESHOLD=0.6
# Confidence on emitted `pictured` hints (core caps name-type aliases at 0.9 regardless).
# FACE_HINT_CONFIDENCE=0.6
# Delay between photos during a scan pass (ms); 0 = no throttle.
# FACE_THROTTLE_MS=0
# Where per-photo face state and the cluster centroids/labels live.
# PHOTO_EXIF_FACE_STATE_PATH=/home/you/.life-context/photo-exif-faces.json
# PHOTO_EXIF_FACE_CLUSTERS_PATH=/home/you/.life-context/photo-exif-face-clusters.json

# `node face-worker.js suggest-labels` (#84): distance threshold for matching a contact's own
# preserved photo (core's CONTACTS_RAW_DIR, from vCard PHOTO import) against an unlabeled
# cluster centroid. Separate from FACE_MATCH_THRESHOLD — a posed contact photo and a candid
# camera-roll photo differ enough that cross-source matching may need a different threshold.
# Defaults to FACE_MATCH_THRESHOLD if unset. Only ever PRINTS suggestions — never writes a
# label. Requires this connector's process to be able to read the raw_path LifeContext returns
# (same machine or a shared/synced volume as core's CONTACTS_RAW_DIR — there is no endpoint to
# fetch the bytes over HTTP). See README "Face detection" for the suggest-labels workflow.
# FACE_SEED_THRESHOLD=0.6
