# Where LifeContext is running and its shared secret (set to the same value as BRAIN_SECRET_KEY
# in the core server's own .env — that's the literal env var name life-context reads).
LIFECONTEXT_URL=http://localhost:3000
LIFECONTEXT_API_KEY=change-this-to-a-long-secure-token

# Root of the photo archive to scan (recursively). Required for both scan.js and caption-worker.js.
PHOTO_ROOT=/path/to/your/photos

# scan.js: where the "already scanned, unchanged" cache lives (mtime+size keyed).
# PHOTO_EXIF_MANIFEST_PATH=/home/you/.life-context/photo-exif-manifest.json

# caption-worker.js: local Ollama endpoint — uses Ollama's NATIVE /api/generate (not the
# OpenAI-compat /v1 endpoint), since that's what supports sending image data — and the vision
# model to use.
# VLM_BASE_URL=http://localhost:11434
# VLM_MODEL=llava
# VLM_PROMPT=Describe this photo in one concise sentence, focused on what's happening and who or what is visible.

# caption-worker.js: delay between captions (ms) — keeps this a genuinely low-priority,
# background-only load on whatever machine runs the VLM.
# VLM_THROTTLE_MS=2000

# caption-worker.js: where the "already captioned" state lives.
# PHOTO_EXIF_CAPTION_STATE_PATH=/home/you/.life-context/photo-exif-captions.json
