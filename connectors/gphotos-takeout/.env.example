# Where LifeContext is running and its shared secret (set to the same value as LIFECONTEXT_API_KEY
# in the core server's own .env — that's the literal env var name life-context reads).
LIFECONTEXT_URL=http://localhost:3000
LIFECONTEXT_API_KEY=change-this-to-a-long-secure-token

# Root of the unzipped Google Takeout export. Point this at either the "Takeout" folder or the
# "Google Photos" folder inside it — the connector auto-descends into "Google Photos" if present.
TAKEOUT_ROOT=/path/to/Takeout

# Which albums are people (copy config.example.json -> config.json and edit). Default: config.json
# next to this connector.
# GPHOTOS_PEOPLE_CONFIG=/path/to/config.json

# Where the "already sent, unchanged" + content-hash cache lives (keyed so re-runs skip unchanged
# files without re-hashing them).
# GPHOTOS_MANIFEST_PATH=/home/you/.life-context/gphotos-takeout-manifest.json

# Where payloads are spooled when the server is unreachable (flushed on the next run). Must end
# in -spool.jsonl to be covered by the repo's .gitignore.
# GPHOTOS_SPOOL_PATH=/home/you/.life-context/gphotos-takeout-spool.jsonl
