# Where LifeContext is running and its shared secret (set to the same value as LIFECONTEXT_API_KEY
# in the core server's own .env — that's the literal env var name life-context reads).
LIFECONTEXT_URL=http://localhost:3000
LIFECONTEXT_API_KEY=change-this-to-a-long-secure-token

# Root of the document tree to scan (recursively, .pdf/.docx/.xlsx/.pptx).
# Required for both scan.js and ocr-worker.js.
DOCUMENTS_SCAN_ROOT=/path/to/your/documents

# scan.js: where the "already scanned, unchanged" cache lives (mtime+size keyed).
# DOCUMENTS_MANIFEST_PATH=/home/you/.life-context/documents-manifest.json

# scan.js: skip files larger than this (MB) — every extractor buffers the whole file.
# DOCUMENTS_MAX_FILE_MB=50

# Both scripts: per-file text_repr cap in chars (head+tail truncated above it; hard ceiling
# 100000 so a batch request always fits the ingest API's 256KB body cap).
# DOCUMENTS_TEXT_REPR_MAX_CHARS=12000

# Both scripts: where the OCR work queue lives (written by scan.js, drained by ocr-worker.js).
# DOCUMENTS_OCR_QUEUE_PATH=/home/you/.life-context/documents-ocr-queue.json

# ocr-worker.js: tesseract language, page budget per PDF, and delay between files (ms) —
# keeps it a genuinely low-priority, background-only load. The ~15MB language model is
# downloaded once and cached at DOCUMENTS_OCR_CACHE_PATH; set DOCUMENTS_OCR_LANG_PATH to
# fetch it from a local tessdata mirror instead of tesseract.js's CDN (air-gapped hosts).
# DOCUMENTS_OCR_LANG=eng
# DOCUMENTS_OCR_MAX_PAGES=20
# DOCUMENTS_OCR_THROTTLE_MS=1000
# DOCUMENTS_OCR_CACHE_PATH=/home/you/.life-context/tesseract
# DOCUMENTS_OCR_LANG_PATH=https://your-mirror/tessdata

# --- vendor-worker.js (#123): vendor/amount/date extraction from bills & receipts ---
# The extraction work queue (written by scan.js for text-layer docs and by ocr-worker.js for OCR'd
# image PDFs; drained by vendor-worker.js).
# DOCUMENTS_EXTRACT_QUEUE_PATH=/home/you/.life-context/documents-extract-queue.json
# Leading chars of each document's text_repr fed to the extractor (vendor/amount/date sit up top);
# caps only the LLM input, the full text_repr is still resent unchanged. Ceiling 20000.
# DOCUMENTS_EXTRACT_MAX_CHARS=4000
# Delay between documents (ms) — keeps it background-only, like the OCR throttle.
# DOCUMENTS_EXTRACT_THROTTLE_MS=1000
# The extractor LLM: any OpenAI-compatible /chat/completions endpoint (local Ollama by default).
# This is extraction, not embedding, so a connector may call it (contract §1.2).
# DOCUMENTS_LLM_BASE_URL=http://localhost:11434/v1
# DOCUMENTS_LLM_MODEL=qwen3:8b
# DOCUMENTS_LLM_API_KEY=   # only if the endpoint requires bearer auth
