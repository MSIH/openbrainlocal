# Where LifeContext is running and its shared secret (set to the same value as BRAIN_SECRET_KEY
# in the core server's own .env — that's the literal env var name life-context reads). Must be
# reachable from wherever this hook runs — on Claude Code web that means a public/tunnel URL,
# not localhost.
LIFECONTEXT_URL=http://localhost:3000
LIFECONTEXT_API_KEY=change-this-to-a-long-secure-token

# --- Summarizer provider ---
# CHAT_PROVIDER=claude-cli (default) shells out to the `claude` binary already authenticated in
# this environment (subscription OAuth or ANTHROPIC_API_KEY) — no local LLM, no separate key,
# works identically on a laptop or a Claude Code web container. Nothing below needs setting for
# this default; CHAT_MODEL defaults to 'haiku' (cheap/fast, plenty for a short summary) and can
# be overridden to any Claude Code model alias (e.g. 'sonnet', 'opus').
# CHAT_PROVIDER=claude-cli
# CHAT_MODEL=haiku

# CHAT_PROVIDER=openai switches to the original OpenAI-compatible /chat/completions path — Ollama
# by default, or LM Studio's http://localhost:1234/v1, or any hosted provider that accepts bearer
# auth via CHAT_API_KEY (omit CHAT_API_KEY for an unauthenticated local endpoint like Ollama's).
# CHAT_PROVIDER=openai
# CHAT_BASE_URL=http://localhost:11434/v1
# CHAT_MODEL=qwen3:8b
# CHAT_API_KEY=

# Optional: override where failed ingests get spooled for retry on the next session
# (default: ~/.life-context/devsession-spool.jsonl). Note: on ephemeral Claude Code web
# containers a spooled payload does not survive container reclaim.
# DEVSESSION_SPOOL_PATH=/home/you/.life-context/devsession-spool.jsonl
