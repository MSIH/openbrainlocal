# Where LifeContext is running and its shared secret (set to the same value as LIFECONTEXT_API_KEY
# in the core server's own .env — that's the literal env var name life-context reads). Point
# this at a LAN IP to run the connector on a different machine than the server (e.g. a Mac Mini
# reading its own chat.db, syncing to a LifeContext server elsewhere on the network) — that's
# the only change needed; the connector itself is identical either way.
LIFECONTEXT_URL=http://localhost:3000
LIFECONTEXT_API_KEY=change-this-to-a-long-secure-token

# Path to the Messages database. Defaults to the real one on macOS; override for testing or
# for a copy pulled from a backup.
# IMESSAGE_DB_PATH=/Users/you/Library/Messages/chat.db

# Where the sync cursor (last processed ROWID) is persisted between runs.
# IMESSAGE_STATE_PATH=/Users/you/.life-context/imessage-cursor.json

# How many chat.db rows to read per SQL page during backfill (each page is sent to LifeContext
# in sub-batches of up to 100, the ingest contract's per-call cap).
# IMESSAGE_DB_PAGE_SIZE=500

# --watch mode: how often (ms) to poll chat.db for new rows after the initial backfill.
# IMESSAGE_POLL_INTERVAL_MS=15000
