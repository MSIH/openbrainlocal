# Copy to .env and fill in. The server hard-exits if LIFECONTEXT_API_KEY is unset
# or left at this placeholder value.

# Required — a long, random secret. Clients send it as the x-api-key header.
LIFECONTEXT_API_KEY=change-this-to-a-long-secure-token

# Optional — capability-URL token for the claude.ai web MCP connector, which has no field for
# a custom header or static API key (only needed for that client — see issue #112). Unset =
# feature off, every /:token/mcp request 404s. Generate:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64url'))"
# This is a lower-trust secret than LIFECONTEXT_API_KEY: it rides in the URL, so it lands in
# Cloudflare edge/proxy access logs. Rotate independently by changing this value and updating
# the connector URL — it never invalidates LIFECONTEXT_API_KEY.
# MCP_URL_TOKEN=

# Optional — defaults to 3000.
PORT=3000

# Optional — Express 'trust proxy' hop count; defaults to 1 (one reverse proxy in front,
# e.g. Cloudflare Tunnel — docs/07-cloudflare-tunnel-setup.md). Set 0 to never trust
# forwarded headers (direct-only installs).
TRUST_PROXY=1

# --- Store ---
# Local SQLite file. Override to point migrations/tests at a throwaway DB.
DB_PATH=life-context.db
# Where npm run import:contacts writes decoded vCard PHOTO bytes (contact artifacts' raw_path).
CONTACTS_RAW_DIR=raw/contacts

# --- Embedding / LLM gateway (local Ollama, OpenAI-compatible) ---
OLLAMA_BASE_URL=http://localhost:11434/v1
# Embedding model. VECTOR_DIMENSION MUST equal its output length (qwen3-embedding:0.6b -> 1024).
# Changing the model means changing the dimension AND re-embedding.
EMBEDDING_MODEL=qwen3-embedding:0.6b
VECTOR_DIMENSION=1024
# Chat model used only by the query planner to parse a query into filters. Optional at
# runtime: if it's unreachable, search degrades gracefully to pure semantic + keyword.
QUERY_MODEL=qwen2.5:3b
# Request timeout (ms) for the embedding/LLM gateway — bounds a hung Ollama.
EMBED_TIMEOUT_MS=60000

# --- Hybrid search tuning (optional) ---
RRF_K=60           # reciprocal-rank-fusion constant
KNN_OVERFETCH=5    # over-fetch factor before filtering/fusion (k = limit * this, clamped)
KNN_MIN=50         # floor on k so fusion has depth
KNN_MAX=500        # ceiling on k (perf guard)
GEO_RADIUS_DEFAULT_KM=25   # default radius for `near` geo-search when radius_km is omitted (#68)
GEO_RADIUS_MAX_KM=500      # clamp ceiling on radius_km

# --- Consolidation: nightly daily digests (optional — docs/06-consolidation.md) ---
DIGEST_MODEL=qwen3:8b     # chat model that writes the digest
DIGEST_TIMEOUT_MS=120000  # per-call timeout for digest generation
DIGEST_MAX_ARTIFACTS=200  # max artifacts fed to the model per day
DIGEST_TEXT_CLIP=500      # chars of each artifact's text_repr given to the model
DIGEST_TIMELINE_DAYS=14   # timeline spans >= this prefer digests over raw rows
