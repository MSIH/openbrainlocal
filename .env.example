# Copy to .env and fill in. The server hard-exits if LIFECONTEXT_API_KEY is unset
# or left at this placeholder value.

# Required — a long, random secret. Clients send it as the x-api-key header.
LIFECONTEXT_API_KEY=change-this-to-a-long-secure-token

# Optional — capability-URL token for the claude.ai web MCP connector, which has no field for
# a custom header or static API key (only needed for that client — see issue #112). Unset =
# feature off, every /:token/mcp request 404s. Generate:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64url'))"
# This is a lower-trust secret than LIFECONTEXT_API_KEY: it rides in the URL, so it lands in
# Cloudflare edge/proxy access logs. Rotate independently by changing this value and updating
# the connector URL — it never invalidates LIFECONTEXT_API_KEY.
# MCP_URL_TOKEN=

# Optional — capability-URL token for the browser web UI (#161). A SEPARATE secret from
# LIFECONTEXT_API_KEY and MCP_URL_TOKEN so each surface rotates on its own. When SET, the UI is
# served only at /ui/<token>/chat.html (a bookmarkable capability URL) and this token also authorizes
# /api calls, so the bookmarked page works with no manual key entry; the bare /ui 404s. When UNSET,
# the UI stays at the plain /ui mount (localhost dev — no change). Like MCP_URL_TOKEN it rides in the
# URL (edge/proxy logs, browser history, Referer), so it's a browser-bookmark convenience credential —
# front /ui with Cloudflare Access for internet exposure (see docs/07). Generate:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64url'))"
# UI_URL_TOKEN=

# --- Access logging (all surfaces: /api, /mcp, /ui) — #178 ---
# One request-logging middleware appends a per-request line (method/path/status/client-IP/latency/
# surface/auth) to a daily file logs/access/access-YYYY-MM-DD.log. Secrets are redacted before
# writing (the ?api_key= query value and capability path tokens /<token>/mcp, /<token>/ui/…) and
# request bodies are NEVER logged — metadata only. 401 / wrong-token 404 / 429 are flagged so probes
# are visible. On boot it prunes files older than the retention window and (Windows) NTFS-compresses
# the folder. All optional — defaults shown.
ACCESS_LOG_ENABLED=true          # set false (or 0/no/off) to disable access logging entirely
ACCESS_LOG_DIR=logs/access       # where the daily files live (gitignored)
ACCESS_LOG_RETENTION_DAYS=90     # boot prunes dated files older than this; 0/unset keeps 90

# Optional — defaults to 3000.
PORT=3000

# Optional — Express 'trust proxy' hop count; defaults to 1 (one reverse proxy in front,
# e.g. Cloudflare Tunnel — docs/07-cloudflare-tunnel-setup.md). Set 0 to never trust
# forwarded headers (direct-only installs).
TRUST_PROXY=1

# --- Store ---
# Local SQLite file. Override to point migrations/tests at a throwaway DB.
DB_PATH=life-context.db
# Where npm run import:contacts writes decoded vCard PHOTO bytes (contact artifacts' raw_path).
# The contacts UI (docs/09) also writes uploaded contact photos here, content-addressed.
CONTACTS_RAW_DIR=raw/contacts
# Max bytes for a contacts-UI photo upload (413 over this); defaults to 10 MB.
CONTACT_PHOTO_MAX_BYTES=10485760

# --- Embedding / LLM gateway (local Ollama, OpenAI-compatible) ---
OLLAMA_BASE_URL=http://localhost:11434/v1
# Embedding model. VECTOR_DIMENSION MUST equal its output length (qwen3-embedding:0.6b -> 1024).
# Changing the model means changing the dimension AND re-embedding.
EMBEDDING_MODEL=qwen3-embedding:0.6b
VECTOR_DIMENSION=1024
# Chat model used only by the query planner to parse a query into filters. Optional at
# runtime: if it's unreachable, search degrades gracefully to pure semantic + keyword.
# CPU-only host? A 3B planner can take >10s per query. Use a smaller model (qwen2.5:1.5b or
# 0.5b) for a faster plan, or turn the planner off entirely (QUERY_PLANNER_ENABLED=false below).
# EMBEDDING_MODEL/VECTOR_DIMENSION are unaffected. A GPU removes the slowness outright.
QUERY_MODEL=qwen2.5:3b
# Query-planner controls (#179). The planner adds time/place/entity/type filters WHEN it responds
# in time; on a CPU-only box it often can't, so search fails over to pure-semantic fast instead of
# stalling. QUERY_PLAN_TIMEOUT_MS bounds the single planner attempt (ms) — a fast/GPU host that
# answers within it still gets planned filters. QUERY_PLANNER_ENABLED=false skips the planner LLM
# entirely (search == pure semantic + keyword, sub-second) for a box where it never beats the timeout.
QUERY_PLAN_TIMEOUT_MS=2500
QUERY_PLANNER_ENABLED=true
# Boot-time warm-up (#247): preloads QUERY_MODEL via Ollama's native API so the first real query
# doesn't pay a cold-load that alone can exceed QUERY_PLAN_TIMEOUT_MS. QUERY_MODEL_KEEP_ALIVE is
# how long Ollama keeps it resident after that; QUERY_MODEL_WARMUP_TIMEOUT_MS bounds the one-shot
# warm-up call (longer than QUERY_PLAN_TIMEOUT_MS — a cold load is expected to be slow). Skipped
# entirely when QUERY_PLANNER_ENABLED=false.
QUERY_MODEL_KEEP_ALIVE=30m
QUERY_MODEL_WARMUP_TIMEOUT_MS=60000
# Request timeout (ms) for the embedding/LLM gateway — bounds a hung Ollama.
EMBED_TIMEOUT_MS=60000

# --- Hybrid search tuning (optional) ---
RRF_K=60           # reciprocal-rank-fusion constant
KNN_OVERFETCH=5    # over-fetch factor before filtering/fusion (k = limit * this, clamped)
KNN_MIN=50         # floor on k so fusion has depth
KNN_MAX=500        # ceiling on k (perf guard)
GEO_RADIUS_DEFAULT_KM=25   # default radius for `near` geo-search when radius_km is omitted (#68)
GEO_RADIUS_MAX_KM=500      # clamp ceiling on radius_km

# --- Consolidation: nightly daily digests (optional — docs/06-consolidation.md) ---
DIGEST_MODEL=qwen3:8b     # chat model that writes the digest
DIGEST_TIMEOUT_MS=120000  # per-call timeout for digest generation
DIGEST_MAX_ARTIFACTS=200  # max artifacts fed to the model per day
DIGEST_TEXT_CLIP=500      # chars of each artifact's text_repr given to the model
DIGEST_TIMELINE_DAYS=14   # timeline spans >= this prefer digests over raw rows
