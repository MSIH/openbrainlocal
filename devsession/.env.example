# Where LifeContext is running and its shared secret (matches BRAIN_SECRET_KEY in the core .env)
BRAIN_URL=http://localhost:3000
BRAIN_SECRET_KEY=change-this-to-a-long-secure-token

# Local OpenAI-compatible chat endpoint used to summarize the session (Ollama by default;
# point at LM Studio's http://localhost:1234/v1 instead if you run chat there for GPU offload)
CHAT_BASE_URL=http://localhost:11434/v1
CHAT_MODEL=qwen3:8b

# Optional: override where failed ingests get spooled for retry on the next session
# (default: ~/.life-context/devsession-spool.jsonl)
# DEVSESSION_SPOOL_PATH=/home/you/.life-context/devsession-spool.jsonl
